<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>¿Who Knows?</title>
  <link rel="stylesheet" href="/output.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="page">
  <div class="border-b border-zinc-200 dark:border-zinc-800">
    <nav class="max-w-2xl mx-auto px-4 sm:px-5 py-4 flex items-center justify-between gap-4">
      <h1 class="font-serif text-xl">
        <a id="nav-logo" href="/" class="hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors">¿Who Knows?</a>
      </h1>
      <div class="flex items-center gap-4 text-sm">
<% if session[:user_id] %>
  <form action="/logout" method="post" style="display:inline">
    <button type="submit" id="nav-logout" class="text-zinc-500 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors cursor-pointer bg-transparent border-0 p-0">
      Log out [<%= session[:username] %>]
    </button>
  </form>
<% else %>
          <a id="nav-login" href="/login" class="text-zinc-500 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Log in</a>
          <a id="nav-register" href="/register" class="text-zinc-500 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Register</a>
        <% end %>
      </div>
    </nav>
  </div>

  <% if session[:flash] %>
    <div class="max-w-2xl mx-auto w-full px-4 sm:px-5 pt-5">
      <% Array(session.delete(:flash)).each do |message| %>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 border-l-2 border-zinc-300 dark:border-zinc-600 pl-3"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <main class="flex-1 max-w-2xl mx-auto w-full px-4 sm:px-5 py-8 sm:py-10">
    <%= yield %>
  </main>

  <footer class="border-t border-zinc-200 dark:border-zinc-800 py-4">
    <div class="max-w-2xl mx-auto px-4 sm:px-5 flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-600">
      <span>¿Who Knows? &copy; 2009</span>
      <a href="/about" class="hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors">About</a>
    </div>
  </footer>

</body>
</html>
