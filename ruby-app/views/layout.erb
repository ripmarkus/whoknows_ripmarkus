<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>¿Who Knows?</title>
  <link rel="stylesheet" href="/output.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="page">
  <div class="navigation">
    <nav>
      <h1><a id="nav-logo" href="/">¿Who Knows?</a></h1>
      <% if session[:user_id] %>
        <a id="nav-logout" href="/logout">Log out [<%= session[:username] %>]</a>
      <% else %>
        <a id="nav-login" href="/login">Log in</a>
        <a id="nav-register" href="/register">Register</a>
      <% end %>
    </nav>
  </div>

  <% if session[:flash] %>
    <div class="max-w-2xl mx-auto w-full px-4 sm:px-5 pt-5">
      <% Array(session.delete(:flash)).each do |message| %>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 border-l-2 border-zinc-300 dark:border-zinc-600 pl-3"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <main class="flex-1 max-w-2xl mx-auto w-full px-4 sm:px-5 py-8 sm:py-10">
    <%= yield %>
  </main>

  <footer class="border-t border-zinc-200 dark:border-zinc-800 py-4">
    <div class="max-w-2xl mx-auto px-4 sm:px-5 flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-600">
      <span>¿Who Knows? &copy; 2009</span>
      <a href="/about" class="hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors">About</a>
    </div>
  </footer>

</body>
</html>
