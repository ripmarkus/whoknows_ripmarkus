<% @title = 'Change Password' %>
<div class="max-w-xs w-full pt-4">
  <h1 class="font-serif text-xl sm:text-2xl text-zinc-900 dark:text-zinc-100 mb-4">Change Your Password</h1>

  <p class="text-sm text-red-500 dark:text-red-400 mb-6">Your account was affected by a security breach. You must set a new password to continue.</p>

  <% if error %>
    <p class="text-sm text-red-500 dark:text-red-400 mb-6"><%= error %></p>
  <% end %>

  <form action="/change-password" method="POST" class="space-y-5">
    <div>
      <label class="block text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-2">Current Password</label>
      <input type="password" name="current_password" required
        class="w-full px-3 py-2.5 text-sm bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded text-zinc-800 dark:text-zinc-200 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-500 transition-colors"/>
    </div>
    <div>
      <label class="block text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-2">New Password</label>
      <input type="password" name="new_password" required
        class="w-full px-3 py-2.5 text-sm bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded text-zinc-800 dark:text-zinc-200 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-500 transition-colors"/>
    </div>
    <div>
      <label class="block text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-2">Confirm New Password</label>
      <input type="password" name="new_password2" required
        class="w-full px-3 py-2.5 text-sm bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded text-zinc-800 dark:text-zinc-200 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-500 transition-colors"/>
    </div>
    <button type="submit"
      class="w-full py-2.5 text-sm bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 rounded hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors">
      Update Password
    </button>
  </form>
</div>
