# WhoKnows Application - Multi-language Repository
# Ruby + Python applications with shared patterns

# === MkDocs ===
site/

# === Common Patterns ===
# Environment and secrets
.env
.env.*
*.log
tmp/
ruby-app/public/output.css

# Database files
*.db
*.sqlite3
*.sqlite3-journal

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor and IDE files
# VS Code - ignore personal settings but keep shared project config
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Other editors
.idea/
*.swp
*.swo
*~

# === Ruby-specific ===
# Gem packages
*.gem
*.rbc

# Ruby coverage and test results
coverage/
spec/reports/
spec/examples.txt
test/tmp/
test/version_tmp/

# Bundler
.bundle/
vendor/bundle/
**/vendor/bundle/
vendor/cache/
lib/bundler/man/

# RubyGems build artifacts
pkg/
InstalledFiles

# Ruby documentation
.yardoc/
_yardoc/
doc/
rdoc/

# Generated CSS output
ruby-app/public/output.css

# Ruby debugging
.byebug_history
.pry_history

# RVM/rbenv
.rvmrc
.ruby-version
.ruby-gemset

# === Python-specific ===
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

